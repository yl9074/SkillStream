# === Python Cache ===
# Compiled Python files automatically generated by the system. Not needed for sharing.
__pycache__/
*.pyc
*.pyo
*.pyd

# === Local Database ===
# Local SQLite database. Do not upload to prevent overwriting team members' local test data.
db.sqlite3

